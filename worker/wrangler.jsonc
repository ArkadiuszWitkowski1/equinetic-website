{
  "$schema": "./node_modules/wrangler/config-schema.json",

  "name": "equinetic-contact-api",
  "main": "src/index.js",
  "compatibility_date": "2026-07-13",

  // Zachowaj FORMSPREE_ENDPOINT ustawiony w panelu Cloudflare.
  "keep_vars": true,

  "workers_dev": true,

  "ratelimits": [
    {
      "name": "CONTACT_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 3,
        "period": 60
      }
    }
  ]
}
